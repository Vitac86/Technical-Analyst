# Frontend local-only environment variables.
# Copy this file to `.env.local` and fill in values for personal development builds.
# NEVER commit `.env.local` to git. NEVER paste a real token into this file.
#
# Optional: a default read-only BCS refresh token used when no session token has
# been entered in Settings. Used only at build time; the value is bundled into
# the local APK build and is NOT written to localStorage, IndexedDB, or any log.
# If a user enters their own token in Settings, the user token overrides this
# default for the current session.
#
# Public GitHub releases should preferably NOT include personal tokens.
# If a token was exposed, rotate it in BCS.

VITE_DEFAULT_BCS_REFRESH_TOKEN=<your_read_only_refresh_token>
